[Unit]
Description=AI Stack (Ollama Intel Arc + Open WebUI + Pipelines + Open Terminal)
After=docker.service
Requires=docker.service

[Service]
# GPU pre-flight — validates Intel Arc node before starting containers
ExecStartPre=/usr/bin/bash ${INSTALL_DIR}/scripts/check-arc-gpu.sh
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=${INSTALL_DIR}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
User=${STACK_USER}
Group=docker

[Install]
WantedBy=multi-user.target
